<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE RSyntaxTheme SYSTEM "theme.dtd">

<RSyntaxTheme version="1.0">

    <!-- Base font optional -->
    <!--<baseFont family="Consolas" size="13"/>-->

    <!-- General editor colors -->
    <background color="293134" />
    <caret color="c1cbc2" />
    <selection useFG="false" bg="404E51" roundedEdges="false" />
    <currentLineHighlight color="2F393C" fade="false" />
    <marginLine fg="394448" />
    <markAllHighlight color="6b8189" />
    <markOccurrencesHighlight color="5b7179" border="false" />
    <matchedBracket fg="E8E2B7" bg="465457" highlightBoth="false" animate="true" />
    <hyperlinks fg="a082bd" />

    <secondaryLanguages>
        <language index="1" bg="333344" />
        <language index="2" bg="223322" />
        <language index="3" bg="332222" />
    </secondaryLanguages>

    <!-- Gutter -->
    <gutterBorder color="81969A" />
    <lineNumbers fg="81969A" currentFG="a9b7c6" />
    <foldIndicator fg="6A8088" armedFg="a9b7c6" iconBg="2f383c" iconArmedBg="3f484c" />
    <iconRowHeader activeLineRange="3399ff" />

    <!-- Syntax tokens -->
    <tokenStyles>

        <!-- Variables / identifiers -->
        <style token="IDENTIFIER" fg="D7DEE9" />

        <!-- Reserved words: si, sino, mientras, retornar, imprimir, leer -->
        <style token="RESERVED_WORD" fg="93C763" bold="true" />

        <!-- Types: entero, real, cadena, booleano, vacio -->
        <style token="DATA_TYPE" fg="7AA6DA" bold="true" />
        <style token="RESERVED_WORD_2" fg="7AA6DA" bold="true" />

        <!-- Booleans: verdadero, falso -->
        <style token="LITERAL_BOOLEAN" fg="93C763" bold="true" />

        <!-- Numbers -->
        <style token="LITERAL_NUMBER_DECIMAL_INT" fg="FFCD22" />
        <style token="LITERAL_NUMBER_FLOAT" fg="FFCD22" />
        <style token="LITERAL_NUMBER_HEXADECIMAL" fg="FFCD22" />

        <!-- Strings -->
        <style token="LITERAL_STRING_DOUBLE_QUOTE" fg="EC7600" />
        <style token="LITERAL_CHAR" fg="EC7600" />
        <style token="LITERAL_BACKQUOTE" fg="EC7600" />

        <!-- Functions -->
        <style token="FUNCTION" fg="E0E2E4" bold="true" />

        <!-- Operators -->
        <style token="OPERATOR" fg="E8E2B7" bold="true" />

        <!-- Separators: (), {}, ; , -->
        <style token="SEPARATOR" fg="C9D1D9" />

        <!-- Comments -->
        <style token="COMMENT_DOCUMENTATION" fg="4CAF50" italic="true" />
        <style token="COMMENT_EOL" fg="4CAF50" italic="true" />
        <style token="COMMENT_MULTILINE" fg="4CAF50" italic="true" />
        <style token="COMMENT_KEYWORD" fg="4CAF50" italic="true" />
        <style token="COMMENT_MARKUP" fg="4CAF50" italic="true" />
        <style token="MARKUP_COMMENT" fg="4CAF50" italic="true" />

        <!-- Optional extras -->
        <style token="ANNOTATION" fg="E8E2B7" />
        <style token="VARIABLE" fg="ae9fbf" />
        <style token="WHITESPACE" fg="E0E2E4" />
        <style token="PREPROCESSOR" fg="A082BD" />
        <style token="REGEX" fg="d39745" />

        <!-- Errors -->
        <style token="ERROR_IDENTIFIER" fg="FFFFFF" bg="B71C1C" />
        <style token="ERROR_NUMBER_FORMAT" fg="FFFFFF" bg="B71C1C" />
        <style token="ERROR_STRING_DOUBLE" fg="FFFFFF" bg="B71C1C" />
        <style token="ERROR_CHAR" fg="FFFFFF" bg="B71C1C" />

    </tokenStyles>

</RSyntaxTheme>